# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Code generation
# *.g.dart files are committed intentionally — Isar requires them at build time
*.freezed.dart
*.mocks.dart

# Secrets (excluded from open-source; included here for private client repo handover)
# google-services.json, GoogleService-Info.plist, key.properties, *.jks → committed
.env
.env.*
firebase_options.dart
